{
  "name": "tiktok-studio-remotion",
  "version": "1.0.0",
  "private": true,
  "description": "Remotion subproject for TikTok Studio script-driven overlays/effects (templates + bespoke render batch entrypoint).",
  "type": "module",
  "scripts": {
    "catalog:build": "tsx scripts/export-catalog.mjs",
    "validate": "node scripts/validate-component.mjs",
    "render": "tsx render/render_cue.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@remotion/bundler": "4.0.489",
    "@remotion/renderer": "4.0.489",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "remotion": "4.0.489",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@remotion/cli": "4.0.489",
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1",
    "esbuild": "0.24.0",
    "tsx": "4.19.2",
    "typescript": "5.6.3"
  }
}
